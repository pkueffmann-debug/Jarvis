{
  "name": "jarvis",
  "version": "0.2.1",
  "description": "JARVIS — AI Desktop Assistant",
  "author": "Paul Küffmann <p.kueffmann@icloud.com>",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/generate-icon.js",
    "icon": "node scripts/generate-icon.js",
    "dev": "concurrently -n vite,electron -c cyan,yellow \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "npm run dist:dir && node scripts/create-dmg.js",
    "dist:dir": "npm run build && electron-builder --mac --dir --config",
    "dist:win": "npm run build && electron-builder --win --config",
    "dist:win:portable": "npm run build && electron-builder --win portable --config",
    "dmg": "node scripts/create-dmg.js",
    "backend": "cd backend && node server.js",
    "backend:dev": "cd backend && node --watch server.js",
    "deploy:backend": "cd backend && railway up --detach",
    "release": "npm run build && electron-builder --mac dmg --publish always",
    "build:wakeword": "bash scripts/build-wakeword.sh"
  },
  "build": {
    "appId": "com.jarvis.app",
    "productName": "JARVIS",
    "icon": "assets/jarvis.icns",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "onboarding/**/*",
      "services/**/*",
      "!services/oww-venv/**",
      "scripts/generate-icon.js",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      },
      {
        "from": "resources/wakeword",
        "to": "wakeword",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/jarvis.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "assets/jarvis.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/jarvis.ico",
      "uninstallerIcon": "assets/jarvis.ico",
      "shortcutName": "JARVIS",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "JARVIS-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "JARVIS-Portable-${version}.exe"
    },
    "dmg": {
      "title": "JARVIS",
      "icon": "assets/jarvis.icns",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 180,
          "type": "file"
        },
        {
          "x": 390,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "pkueffmann-debug",
        "repo": "Jarvis"
      }
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.2",
    "electron-builder": "^26.8.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fontsource/inter": "^5.0.17",
    "@picovoice/porcupine-node": "^4.0.2",
    "@supabase/supabase-js": "^2.105.4",
    "canvas": "^3.2.3",
    "dotenv": "^16.4.1",
    "electron-updater": "^6.8.3",
    "googleapis": "^144.0.0",
    "imapflow": "^1.3.3",
    "node-cron": "^4.2.1",
    "openai": "^4.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
